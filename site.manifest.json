{
  "host": "docs.swarmauri.com",
  "zone": "swarmauri.com",
  "repository": "swarmauri/docs-swarmauri-com",
  "siteKind": "zdx-docs",
  "orchestrator": "npmctl",
  "dnsProvider": "namecheap",
