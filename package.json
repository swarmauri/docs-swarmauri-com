{
  "name": "docs-swarmauri-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "uv run mkdocs serve -f mkdocs.yml -a 0.0.0.0:8000",
    "build": "uv run mkdocs build -f mkdocs.yml",
    "check": "uv run mkdocs build -f mkdocs.yml",
    "docker:build": "docker compose build docs-swarmauri-com",
    "dns:plan": "npmctl plan desired-state/dns.yaml --owner docs-swarmauri-com",
    "dns:apply": "npmctl apply desired-state/dns.yaml --owner docs-swarmauri-com",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "deploy": "docker compose -f docker-compose.yaml up -d --build --force-recreate --no-deps docs-swarmauri-com",
    "dns:doctor": "npmctl dns doctor --provider namecheap",
    "proxy:validate": "npmctl validate desired-state/proxy.yaml",
    "proxy:plan": "npmctl plan desired-state/proxy.yaml --owner docs-swarmauri-com",
    "proxy:apply": "npmctl apply desired-state/proxy.yaml --owner docs-swarmauri-com",
    "proxy:target-check": "node scripts/validate-proxy-target.mjs"
  }
}
